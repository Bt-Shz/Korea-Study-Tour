---
import Header from '../components/Header.astro';
import Navigation from '../components/Navigation.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SitemapNav from '../components/SitemapNav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';
import '../styles/site.css';

interface Props {
  title: string;
  description?: string;
  breadcrumb?: string;
  showBreadcrumb?: boolean;
}

const {
  title,
  description = site.description,
  breadcrumb,
  showBreadcrumb = !!breadcrumb,
} = Astro.props;

const pageTitle = `${title} | ${site.title} | ${site.university}`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/x-icon" href="https://www.cityu.edu.hk/favicon.ico" />
    <link rel="preconnect" href="https://template.cityu.edu.hk" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://template.cityu.edu.hk/template/v2/css/bootstrap/bootstrap.min.css"
    />
    <link rel="stylesheet" href="https://template.cityu.edu.hk/template/v2/css/cityu.base.css" />
    <link
      rel="stylesheet"
      href="https://template.cityu.edu.hk/template/v2/css/fontawesome/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,300;1,400;1,700;1,900&display=swap"
    />
    <link rel="stylesheet" href="https://template.cityu.edu.hk/template/v2/css/aos/aos.css" />
    <link
      rel="stylesheet"
      href="https://template.cityu.edu.hk/template/v2/css/animate.css/animate.min.css"
    />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="author" content={site.university} />
    <meta name="description" content={description} />
    <meta name="keywords" content="City University of Hong Kong, City University, CityUHK" />
    <meta name="robots" content="index, follow" />
  </head>
  <body
    class="cityu-template-2 cityu-template-2-1 cityu-base-layout cityu-base-style ct-prod ct-bootstrap-5 ct-touch ct-xxl ct-breadcrumb ct-submenu ct-sitemap"
  >
    <Header />
    <Navigation currentPath={currentPath} />
    {showBreadcrumb && breadcrumb && <Breadcrumb label={breadcrumb} />}

    <slot name="before-main" />

    <main class="cityu-main" style="min-height: 605px">
      <slot />
    </main>

    <SitemapNav />
    <Footer />

    <script is:inline src="/js/cityu.config.js"></script>
    <script is:inline src="https://template.cityu.edu.hk/template/v2/js/jquery/jquery.min.js"></script>
    <script is:inline src="https://template.cityu.edu.hk/template/v2/js/popper.js/popper.min.js"></script>
    <script is:inline src="https://template.cityu.edu.hk/template/v2/js/bootstrap/bootstrap.min.js"></script>
    <script is:inline src="https://template.cityu.edu.hk/template/v2/js/cityu.base.js"></script>
    <script is:inline async src="https://template.cityu.edu.hk/template/v2/js/aos/aos.js"></script>

    <button
      type="button"
      class="cityu-backtotop"
      id="btn-back-to-top"
      aria-label="Back to top"
      style="display: none"
    >
      <i class="fas fa-chevron-up"></i>
    </button>
  </body>
</html>
