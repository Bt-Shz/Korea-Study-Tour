---
import SiteFooter from '../components/layout/SiteFooter.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import { site } from '../config/site';
import { stripBase } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const pageTitle = title ? `${title} | ${site.title}` : site.title;
const isHome = stripBase(Astro.url.pathname) === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={site.university} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen bg-[#fafafa] text-[#1a1a1a]">
    <SiteHeader isHome={isHome} />

    <main class:list={[!isHome && 'pt-28']}>
      <slot />
    </main>

    <SiteFooter />

    <script is:inline>
      const header = document.getElementById('site-header');
      if (header) {
        const isHome = header.dataset.home === 'true';
        const setScrolled = () => {
          const scrolled = !isHome || window.scrollY > 60;
          header.dataset.scrolled = scrolled ? 'true' : 'false';
        };

        setScrolled();

        if (isHome) {
          window.addEventListener('scroll', setScrolled, { passive: true });
        }

        const menuButton = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = header.querySelector('[data-menu-icon]');
        const closeIcon = header.querySelector('[data-close-icon]');
        const setMenu = (open) => {
          header.dataset.menuOpen = open ? 'true' : 'false';
          // Keep a solid header behind the open dropdown, otherwise the hero
          // image bleeds through the transparent bars on the home page.
          if (open) {
            header.dataset.scrolled = 'true';
          } else {
            setScrolled();
          }
          if (menuButton) {
            menuButton.setAttribute('aria-expanded', open ? 'true' : 'false');
          }
          if (mobileMenu) {
            mobileMenu.setAttribute('aria-hidden', open ? 'false' : 'true');
            mobileMenu.hidden = !open;
          }
          if (menuIcon) {
            menuIcon.classList.toggle('hidden', open);
          }
          if (closeIcon) {
            closeIcon.classList.toggle('hidden', !open);
          }
        };

        setMenu(false);

        if (menuButton) {
          menuButton.addEventListener('click', () => {
            const open = header.dataset.menuOpen !== 'true';
            setMenu(open);
          });
        }

        if (mobileMenu) {
          mobileMenu.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => setMenu(false));
          });
        }
      }

      const hero = document.querySelector('[data-hero]');
      if (hero) {
        const slides = Array.from(hero.querySelectorAll('[data-hero-slide]'));
        const dots = Array.from(hero.querySelectorAll('[data-hero-dot]'));
        const prevButton = hero.querySelector('[data-hero-prev]');
        const nextButton = hero.querySelector('[data-hero-next]');
        const caption = hero.querySelector('[data-hero-caption]');
        let current = 0;
        let timer;

        const setHero = (next) => {
          if (!slides.length) return;
          current = (next + slides.length) % slides.length;
          slides.forEach((slide, index) => {
            slide.style.opacity = index === current ? '1' : '0';
          });
          dots.forEach((dot, index) => {
            dot.style.width = index === current ? '24px' : '6px';
            dot.style.background = index === current ? '#e8411a' : 'rgba(255,255,255,0.4)';
            dot.setAttribute('aria-pressed', index === current ? 'true' : 'false');
          });
          if (caption) {
            caption.textContent = slides[current].dataset.caption || '';
          }
        };

        const restartTimer = () => {
          clearInterval(timer);
          timer = window.setInterval(() => setHero(current + 1), 5000);
        };

        setHero(0);
        restartTimer();

        if (prevButton) {
          prevButton.addEventListener('click', () => {
            setHero(current - 1);
            restartTimer();
          });
        }

        if (nextButton) {
          nextButton.addEventListener('click', () => {
            setHero(current + 1);
            restartTimer();
          });
        }

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = Number(dot.dataset.heroIndex || '0');
            setHero(index);
            restartTimer();
          });
        });
      }

      const filters = Array.from(document.querySelectorAll('[data-social-filter]'));
      const panels = Array.from(document.querySelectorAll('[data-social-panel]'));
      if (filters.length && panels.length) {
        const setFilter = (key) => {
          filters.forEach((button) => {
            const active = button.dataset.filter === key;
            button.dataset.active = active ? 'true' : 'false';
            button.setAttribute('aria-pressed', active ? 'true' : 'false');
          });
          panels.forEach((panel) => {
            panel.hidden = panel.dataset.platform !== key;
          });
        };

        setFilter(filters[0].dataset.filter || 'youtube');
        filters.forEach((button) => {
          button.addEventListener('click', () => setFilter(button.dataset.filter));
        });
      }

    </script>
  </body>
</html>
