---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScheduleDaySection from '../../components/sections/ScheduleDaySection.astro';
import Container from '../../components/ui/Container.astro';
import GradientText from '../../components/ui/GradientText.astro';
import InnerPage from '../../components/layout/InnerPage.astro';
import PageIntro from '../../components/layout/PageIntro.astro';
import { visitSchedule } from '../../data/schedule';
---

<BaseLayout title="Visit Schedule">
  <InnerPage variant="gradient">
    <Container>
      <PageIntro
        eyebrow="Itinerary"
        statValue="18-22"
        statLabel="May 2026"
        dropCap="T"
        scrollHint="Schedule below"
      >
        <Fragment slot="title">
          Five days.<br />
          One <GradientText>journey</GradientText>.
        </Fragment>
        <Fragment slot="lead">
          he Korea Study Tour schedule follows our full five-day journey, covering academic visits,
          city learning, and the final split between return travel and optional extended exploration.
        </Fragment>
        <p slot="body">
          Inspired by the Japan Study Tour format, all days stay visible with clear time blocks,
          event titles, and short descriptions for quick presentation use.
        </p>
      </PageIntro>

      <div class="space-y-6">
        {visitSchedule.map((day) => <ScheduleDaySection {...day} />)}
      </div>
    </Container>
  </InnerPage>
</BaseLayout>
