---
import { getCollection, render } from 'astro:content';
import ArticleBody from '../../components/content/ArticleBody.astro';
import ArticleHeader from '../../components/content/ArticleHeader.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('scheduleEvents', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, time, location, image, date, summary } = entry.data;
---

<ArticleLayout title={title} description={description}>
  <ArticleHeader
    slot="header"
    title={title}
    time={time}
    location={location}
    image={image}
    date={date}
    summary={summary}
    description={description}
  />
  <ArticleBody>
    <Content />
  </ArticleBody>
</ArticleLayout>
