---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
import { site } from '../config/site';
---

<BaseLayout title="About" breadcrumb="About">
  <PageShell
    heading="About"
    lead="Learn about the purpose and destinations of this study tour."
  >
    <p>
      The purpose of this website is to show the highlights of a study tour organized by the
      {site.department} at {site.university}. The trip aims to expose students to a different
      educational system, introduce new collaboration and career opportunities, and expand
      knowledge of local culture and technology.
    </p>

    <div class="content-card">
      <h2>Planned visits</h2>
      <p class="placeholder-note">Destinations and partners will be listed here once confirmed.</p>
      <ul>
        <li>Partner universities — details coming soon</li>
        <li>Industry visits — details coming soon</li>
        <li>Cultural explorations — details coming soon</li>
      </ul>
    </div>

    <p>
      The tour will be led by faculty from the Department of Computer Science. See
      <a href="/team">The Visit Team</a> for organisers and participants.
    </p>
    <p>Enjoy exploring our website as we share highlights from the tour.</p>
  </PageShell>
</BaseLayout>
