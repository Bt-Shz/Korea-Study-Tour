---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/PageShell.astro';
---

<BaseLayout title="The Schedule" breadcrumb="The Schedule">
  <PageShell
    heading="Visit Schedule"
    lead="Day-by-day itinerary for the study tour. Schedule details will be updated before departure."
  >
    <p class="placeholder-note">
      Full schedule with times and locations will be published here.
    </p>

    <div class="schedule-day">
      <h3>Day 1 — Arrival</h3>
      <ul>
        <li>Departure from Hong Kong</li>
        <li>Arrival and orientation</li>
        <li>Evening at leisure</li>
      </ul>
    </div>

    <div class="schedule-day">
      <h3>Day 2 — Academic visits</h3>
      <ul>
        <li>University campus tour (TBC)</li>
        <li>Lab demonstrations and workshops (TBC)</li>
      </ul>
    </div>

    <div class="schedule-day">
      <h3>Day 3 — Industry &amp; academia</h3>
      <ul>
        <li>Company visit (TBC)</li>
        <li>University research showcase (TBC)</li>
      </ul>
    </div>

    <div class="schedule-day">
      <h3>Day 4 — Student-led exploration</h3>
      <ul>
        <li>Self-organised cultural activities in groups</li>
      </ul>
    </div>

    <div class="schedule-day">
      <h3>Day 5 — Departure</h3>
      <ul>
        <li>Final activities and return to Hong Kong</li>
      </ul>
    </div>
  </PageShell>
</BaseLayout>
