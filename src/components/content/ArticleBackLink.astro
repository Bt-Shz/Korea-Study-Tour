---
import Icon from '../Icon.astro';
import { withBase } from '../../utils/paths';

interface Props {
  href?: string;
  label?: string;
}

const { href = '/visit-schedule', label = 'Back to visit schedule' } = Astro.props;
---

<a
  href={withBase(href)}
  class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-primary transition-colors mb-8"
>
  <Icon name="chevron-right" size={16} class="rotate-180" />
  {label}
</a>
