---
import Icon from '../Icon.astro';

interface Props {
  title: string;
  time: string;
  location: string;
  image: string;
  date: string;
  summary: string;
  description?: string;
}

const { title, time, location, image, date, summary, description } = Astro.props;
---

<header class="mb-10">
  <div class="flex flex-wrap items-center justify-center gap-2 text-xs font-semibold uppercase tracking-wide text-primary mb-4">
    <span>{date}</span>
    <span class="text-gray-300" aria-hidden="true">·</span>
    <span class="text-gray-500 normal-case tracking-normal">{summary}</span>
  </div>

  <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">{title}</h1>

  <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-gray-500 mb-6">
    <span class="inline-flex items-center gap-1.5 font-semibold text-primary">
      <Icon name="calendar" size={14} />
      {time}
    </span>
    <span class="inline-flex items-center gap-1.5">
      <Icon name="map-pin" size={14} />
      {location}
    </span>
  </div>

  {
    description && (
      <p class="text-gray-600 leading-relaxed max-w-3xl mx-auto mb-8">{description}</p>
    )
  }

  <div class="relative aspect-[21/9] max-w-4xl mx-auto rounded-2xl overflow-hidden bg-gray-200 shadow-sm">
    <img src={image} alt={title} class="w-full h-full object-cover" />
    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4 md:p-5">
      <div class="flex items-start gap-1.5 max-w-3xl mx-auto">
        <Icon name="map-pin" size={14} class="text-white mt-0.5 shrink-0" />
        <span class="text-sm text-white font-medium leading-tight">{location}</span>
      </div>
    </div>
  </div>
</header>
