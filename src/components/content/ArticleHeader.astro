---
import Icon from '../Icon.astro';
import { withBase } from '../../utils/paths';

interface Props {
  title: string;
  time: string;
  location: string;
  image: string;
  date: string;
  summary: string;
  description?: string;
  variant?: 'default' | 'featured';
  eyebrow?: string;
  extraChip?: string;
}

const {
  title,
  time,
  location,
  image,
  date,
  summary,
  description,
  variant = 'default',
  eyebrow,
  extraChip,
} = Astro.props;

const imageSrc = withBase(image);
---

{
  variant === 'featured' ? (
    <header class="article-header article-header--featured mb-12">
      <div class="article-header-featured__hero" role="button" tabindex="0" aria-label="View full photo">
        <img src={imageSrc} alt={title} class="article-header-featured__image" />
        <div class="article-header-featured__overlay" aria-hidden="true" />
        <div class="article-header-featured__glow" aria-hidden="true" />

        <div class="article-header-featured__zoom-hint" aria-hidden="true">
          <Icon name="zoom-in" size={20} />
        </div>

        <div class="article-header-featured__content">
          <div class="article-header-featured__meta">
            <span class="article-header-featured__eyebrow">{eyebrow ?? 'Academic Visit'}</span>
            <span class="article-header-featured__date">{date}</span>
          </div>

          <h1 class="article-header-featured__title">{title}</h1>
          {summary && <p class="article-header-featured__summary">{summary}</p>}

          <div class="article-header-featured__chips">
            <span class="article-header-featured__chip">
              <Icon name="calendar" size={14} />
              {time}
            </span>
            <span class="article-header-featured__chip">
              <Icon name="map-pin" size={14} />
              {location}
            </span>
            {extraChip && (
              <span class="article-header-featured__chip">
                <Icon name="train" size={14} />
                {extraChip}
              </span>
            )}
          </div>
        </div>
      </div>

      <dialog id="hero-lightbox" class="hero-lightbox" aria-label="Photo lightbox">
        <button class="hero-lightbox__close" aria-label="Close">&#x2715;</button>
        <img src={imageSrc} alt={title} class="hero-lightbox__img" />
      </dialog>
    </header>
  ) : (
    <header class="article-header mb-10">
      <div class="flex flex-wrap items-center justify-center gap-2 text-xs font-semibold uppercase tracking-wide text-primary mb-4">
        <span>{date}</span>
        <span class="text-gray-300" aria-hidden="true">·</span>
        <span class="text-gray-500 normal-case tracking-normal">{summary}</span>
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">{title}</h1>

      <div class="flex flex-wrap items-center justify-center gap-3 text-sm text-gray-500 mb-6">
        <span class="inline-flex items-center gap-1.5 font-semibold text-primary">
          <Icon name="calendar" size={14} />
          {time}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Icon name="map-pin" size={14} />
          {location}
        </span>
      </div>

      {description && (
        <p class="text-gray-600 leading-relaxed max-w-3xl mx-auto mb-8">{description}</p>
      )}

      <div class="relative aspect-[21/9] max-w-4xl mx-auto rounded-2xl overflow-hidden bg-gray-200 shadow-sm">
        <img src={imageSrc} alt={title} class="w-full h-full object-cover" />
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4 md:p-5">
          <div class="flex items-start gap-1.5 max-w-3xl mx-auto">
            <Icon name="map-pin" size={14} class="text-white mt-0.5 shrink-0" />
            <span class="text-sm text-white font-medium leading-tight">{location}</span>
          </div>
        </div>
      </div>
    </header>
  )
}
