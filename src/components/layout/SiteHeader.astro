---
import Icon from '../Icon.astro';
import BrandLogo from '../ui/BrandLogo.astro';
import { navItems } from '../../config/site';

interface Props {
  isHome: boolean;
}

const { isHome } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<header
  id="site-header"
  class="group fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent data-[scrolled=true]:bg-white/95 data-[scrolled=true]:backdrop-blur-md data-[scrolled=true]:shadow-sm data-[scrolled=true]:border-b data-[scrolled=true]:border-gray-100"
  data-home={isHome ? 'true' : 'false'}
  data-scrolled={isHome ? 'false' : 'true'}
  data-menu-open="false"
>
  <div class="max-w-7xl mx-auto px-5 h-16 flex items-center justify-between">
    <a href="https://www.cs.cityu.edu.hk/en" class="flex items-center gap-3" rel="noopener" target="_blank">
      <BrandLogo />
      <div class="leading-tight">
        <div class="text-xs font-semibold tracking-wide text-white group-data-[scrolled=true]:text-primary">
          CityU &middot; CS Department
        </div>
        <div class="text-[10px] text-white/70 group-data-[scrolled=true]:text-gray-500">
          Seoul Visit 2026
        </div>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {
        navItems.map((item) => {
          const active = isActive(item.href);
          return (
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              data-active={active ? 'true' : undefined}
              class="px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 text-white/90 hover:bg-white/15 group-data-[scrolled=true]:text-gray-700 group-data-[scrolled=true]:hover:bg-gray-100 data-[active=true]:bg-primary data-[active=true]:text-white"
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <button
      id="mobile-menu-toggle"
      type="button"
      class="md:hidden p-2 rounded-lg text-white group-data-[scrolled=true]:text-gray-700"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="sr-only">Toggle menu</span>
      <Icon name="menu" size={20} data-menu-icon />
      <Icon name="x" size={20} class="hidden" data-close-icon />
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden bg-white border-t border-gray-100 shadow-xl"
    aria-hidden="true"
    hidden
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="w-full text-left px-5 py-3.5 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:text-primary transition-colors flex items-center justify-between"
        >
          {item.label}
          <Icon name="chevron-right" size={16} class="text-gray-400" />
        </a>
      ))
    }
  </div>
</header>
