---
import { cityuLinks, cityuLogos, footerLinks } from '../../config/site';
---

<footer class="bg-gray-900 text-white py-8">
  <div class="max-w-7xl mx-auto px-5">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center text-sm text-gray-300">
          {
            footerLinks.map((item, index) => (
              <>
                {index > 0 && <span class="mx-1 text-gray-500">·</span>}
                <a href={item.href} rel="noopener" target="_blank" class="hover:text-white transition-colors">
                  {item.label}
                </a>
              </>
            ))
          }
        </div>
        <div class="text-xs text-gray-500 mt-2">© City University of Hong Kong. All Rights Reserved.</div>
      </div>

      <div class="self-start md:self-end">
        <a href={cityuLinks.university} rel="noopener" target="_blank">
          <img src={cityuLogos.verticalReverse} alt="City University of Hong Kong" class="h-11 w-auto" />
        </a>
      </div>
    </div>
  </div>
</footer>
