---
import DropCapQuote from '../ui/DropCapQuote.astro';
import ScrollHint from '../ui/ScrollHint.astro';
import SectionEyebrow from '../ui/SectionEyebrow.astro';

interface Props {
  eyebrow: string;
  statValue: string;
  statLabel: string;
  dropCap: string;
  scrollHint: string;
}

const { eyebrow, statValue, statLabel, dropCap, scrollHint } = Astro.props;
---

<section class="relative mb-14 lg:mb-16">
  <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">
    <div class="max-w-xl">
      <SectionEyebrow>{eyebrow}</SectionEyebrow>
      <h1
        class="font-display text-4xl md:text-5xl font-black tracking-tight leading-[1.08] text-gray-900 mt-1"
      >
        <slot name="title" />
      </h1>
      <div
        class="mt-6 inline-flex items-center gap-2.5 rounded-full border border-gray-200 bg-white px-4 py-2 shadow-sm"
      >
        <span class="text-xl font-black text-primary font-display">{statValue}</span>
        <span class="text-xs uppercase tracking-[0.18em] text-gray-500">{statLabel}</span>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-100 bg-white p-6 md:p-8 shadow-sm">
      <DropCapQuote letter={dropCap} size="md">
        <slot name="lead" />
      </DropCapQuote>
      <div class="mt-4 border-t border-gray-100 pt-4 text-gray-600 leading-relaxed text-[15px] md:text-base">
        <slot name="body" />
      </div>
      <ScrollHint label={scrollHint} />
    </div>
  </div>
</section>
