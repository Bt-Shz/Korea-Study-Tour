---
interface Props {
  name: string;
  role: string;
  email: string;
  department: string;
  image: string;
}

const { name, role, email, department, image } = Astro.props;
---

<div
  class="group relative bg-white rounded-3xl overflow-hidden border border-gray-100 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1 transition-all duration-300 shadow-sm flex flex-col"
>
  <div class="relative aspect-[4/5] overflow-hidden bg-gray-100">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div
      class="absolute top-0 left-0 right-0 h-1 origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 bg-brand-gradient"
    ></div>
    <div class="absolute top-4 left-4">
      <span
        class="inline-block text-[10px] font-bold tracking-[0.18em] uppercase text-white px-2.5 py-1 rounded-full backdrop-blur-md border border-white/20"
        style="background: rgba(200,16,46,0.85);"
      >
        {role}
      </span>
    </div>
    <div class="absolute bottom-0 left-0 right-0 p-5">
      <div class="font-bold text-white text-lg leading-tight" style="text-shadow: 0 2px 8px rgba(0,0,0,0.4);">
        {name}
      </div>
    </div>
  </div>

  <div class="p-5 flex-1 flex flex-col justify-between">
    <div class="text-xs text-gray-500 leading-relaxed">{department}</div>
    <a
      href={`mailto:${email}`}
      class="mt-3 inline-flex items-center gap-1.5 text-xs font-semibold text-primary hover:text-[var(--brand-orange)] transition-colors group/email"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-primary group-hover/email:scale-150 transition-transform"></span>
      {email}
    </a>
  </div>
</div>
