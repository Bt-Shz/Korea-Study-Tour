---
import Icon from '../Icon.astro';

interface Props {
  time: string;
  title: string;
  location: string;
  description: string;
  image: string;
  slug?: string;
  showTimeline?: boolean;
}

const { time, title, location, description, image, slug, showTimeline = true } = Astro.props;
const href = slug ? `/visit-schedule/${slug}` : undefined;

const cardClass =
  'flex flex-col md:flex-row gap-4 bg-gray-50 rounded-xl p-4 transition-colors' +
  (href
    ? ' hover:bg-gray-100 hover:shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary cursor-pointer group'
    : '');
---

<div class="flex gap-6" data-accordion-row>
  <div class="flex flex-col items-center">
    <span class="text-xs font-bold text-primary mb-2 whitespace-nowrap">{time}</span>
    <div class="w-3 h-3 rounded-full shrink-0 bg-brand-gradient"></div>
    {
      showTimeline && (
        <div
          class="w-0.5 flex-1 bg-gradient-to-b from-primary to-gray-200 mt-2 mb-2"
          style="min-height: 60px;"
        ></div>
      )
    }
  </div>

  <div class="flex-1 pb-8 last:pb-0">
    {
      href ? (
        <a href={href} class:list={[cardClass, 'no-underline text-inherit']} aria-label={`Read more about ${title}`}>
          <div class="md:w-48 shrink-0">
            <div class="relative aspect-video rounded-lg overflow-hidden bg-gray-200">
              <img src={image} alt="" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-3">
                <div class="flex items-start gap-1.5">
                  <Icon name="map-pin" size={12} class="text-white mt-0.5 shrink-0" />
                  <span class="text-[11px] text-white font-medium leading-tight">{location}</span>
                </div>
              </div>
            </div>
          </div>
          <div class="flex-1 flex flex-col justify-center">
            <h3 class="font-bold text-gray-900 text-base mb-2 group-hover:text-primary transition-colors">{title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
          </div>
        </a>
      ) : (
        <div class={cardClass}>
          <div class="md:w-48 shrink-0">
            <div class="relative aspect-video rounded-lg overflow-hidden bg-gray-200">
              <img src={image} alt={title} class="w-full h-full object-cover" />
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-3">
                <div class="flex items-start gap-1.5">
                  <Icon name="map-pin" size={12} class="text-white mt-0.5 shrink-0" />
                  <span class="text-[11px] text-white font-medium leading-tight">{location}</span>
                </div>
              </div>
            </div>
          </div>
          <div class="flex-1 flex flex-col justify-center">
            <h3 class="font-bold text-gray-900 text-base mb-2">{title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
          </div>
        </div>
      )
    }
  </div>
</div>
