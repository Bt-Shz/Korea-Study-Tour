---
interface Props {
  time: string;
  title: string;
  description: string;
  variant?: 'default' | 'travel' | 'staying-behind';
}

const { time, title, description, variant = 'default' } = Astro.props;
const isStayingBehind = variant === 'staying-behind';
const isTravel = variant === 'travel';
---

<article
  class:list={[
    'rounded-2xl border p-5 md:p-6',
    isStayingBehind
      ? 'border-orange-200 bg-orange-50'
      : isTravel
        ? 'border-blue-200 bg-blue-50'
        : 'border-gray-200 bg-white',
  ]}
>
  <div class="text-xs uppercase tracking-[0.18em] font-semibold text-gray-500">{time}</div>
  <h3 class="mt-2 text-lg font-bold text-gray-900">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-gray-600">{description}</p>
</article>
