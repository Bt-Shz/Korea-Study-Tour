---
interface Props {
  id: string;
  name: string;
  nickname: string;
  year: string;
  email: string;
  image: string;
}

const { id, name, nickname, year, email, image } = Astro.props;
const isPlaceholder = name === 'Your Full Name' || email === 'yourname-c@my.cityu.edu.hk';
const displayName = nickname ? `${name} (${nickname})` : name;
---

<article class="rounded-2xl border border-gray-200 bg-white p-5 hover:shadow-md transition-shadow">
  <div class="flex items-start gap-4">
    <img src={image} alt={displayName} class="w-16 h-16 rounded-xl object-cover bg-gray-100 shrink-0" />
    <div class="min-w-0 flex-1">
      <div class="text-xs uppercase tracking-[0.14em] text-gray-400">{id}</div>
      <h3 class="font-semibold text-gray-900 leading-tight mt-1">{displayName}</h3>
      <p class="text-sm text-gray-500 mt-1">{year}</p>
      <a href={`mailto:${email}`} class="text-sm text-primary hover:underline break-all mt-1 inline-block">
        {email}
      </a>
    </div>
  </div>
  {isPlaceholder && <p class="mt-3 text-xs text-orange-600 font-medium">Profile coming soon</p>}
</article>
