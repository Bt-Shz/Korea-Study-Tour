---
import { platformAccentColor, type SocialPlatformKey } from '../../data/social';

interface Props {
  title: string;
  thumbnail: string;
  link: string;
  platformKey: SocialPlatformKey;
  type: 'video' | 'short' | 'post';
  hidden?: boolean;
}

const { title, thumbnail, link, platformKey, type, hidden = false } = Astro.props;
const isVideo = type === 'video' || type === 'short';
const accent = platformAccentColor(platformKey);
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  data-social-card
  data-platform={platformKey}
  class="group bg-white rounded-2xl overflow-hidden border border-gray-100 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl flex flex-col shadow-sm"
  hidden={hidden}
>
  <div class="h-1 w-full" style={`background: ${accent};`}></div>
  <div class="relative aspect-video overflow-hidden bg-gray-100">
    <img
      src={thumbnail}
      alt={title}
      class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
    {
      isVideo && (
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-12 h-12 rounded-full bg-white/30 backdrop-blur-md border border-white/50 flex items-center justify-center group-hover:scale-110 group-hover:bg-white/40 transition-all shadow-lg">
            <div class="w-0 h-0 border-t-[7px] border-t-transparent border-l-[12px] border-l-white border-b-[7px] border-b-transparent ml-1"></div>
          </div>
        </div>
      )
    }
  </div>
  <div class="p-5 flex-1 flex flex-col justify-between bg-white">
    <p class="text-gray-800 font-medium text-sm leading-relaxed line-clamp-2 group-hover:text-primary transition-colors">
      {title}
    </p>
  </div>
</a>
