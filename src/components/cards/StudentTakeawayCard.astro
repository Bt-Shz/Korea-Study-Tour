---
interface Props {
  name: string;
  nickname?: string;
  year: string;
  image: string;
  reflection: string;
  /** index used to pick this student's personal accent colour */
  accent?: number;
}

const { name, nickname = '', year, image, reflection, accent = 0 } = Astro.props;

// Every student gets their OWN accent colour — a lively, equal mosaic where no
// one is singled out. Deterministic by position so the wall stays balanced.
const palette: [string, string][] = [
  ['#e8411a', '#c8102e'], // brand red-orange
  ['#2b7fd4', '#0a4d93'], // blue
  ['#10b9c7', '#0a7f8a'], // teal
  ['#8b5cf6', '#6d28d9'], // violet
  ['#10b981', '#047857'], // emerald
  ['#f59e0b', '#d97706'], // amber
  ['#ec4899', '#be185d'], // pink
  ['#6366f1', '#4338ca'], // indigo
  ['#0ea5e9', '#0369a1'], // sky
];
const [c1, c2] = palette[((accent % palette.length) + palette.length) % palette.length];

const isPlaceholder = name === 'Your Full Name' || reflection.trim().length === 0;
const displayName = isPlaceholder ? 'Student Profile' : nickname ? `${name} (${nickname})` : name;
const subtitle = `${year} · Computer Science`;
const displayReflection = isPlaceholder ? 'Reflection coming soon.' : reflection;
---

<article class="takeaway-card" style={`--c1:${c1};--c2:${c2};`}>
  <button
    type="button"
    class="takeaway-card__trigger"
    data-takeaway-trigger
    data-name={displayName}
    data-subtitle={subtitle}
    data-image={image}
    data-reflection={displayReflection}
    data-c1={c1}
    data-c2={c2}
    data-placeholder={isPlaceholder ? 'true' : 'false'}
    aria-haspopup="dialog"
    aria-label={`Read ${displayName}'s full reflection`}
  >
    <span class="takeaway-card__band">
      <span class="takeaway-card__avatar">
        <img src={image} alt="" loading="lazy" />
      </span>
      <span class="takeaway-card__id">
        <span class="takeaway-card__name">{displayName}</span>
        <span class="takeaway-card__sub">{subtitle}</span>
      </span>
    </span>
    <span class="takeaway-card__body">
      <span class="takeaway-card__quote" aria-hidden="true">&ldquo;</span>
      <span class="takeaway-card__text">{displayReflection}</span>
      {!isPlaceholder && (
        <span class="takeaway-card__more" aria-hidden="true">Read more &rarr;</span>
      )}
    </span>
  </button>
</article>

<style>
  .takeaway-card {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    border-radius: 1.25rem;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 8px 24px -16px rgba(15, 23, 42, 0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .takeaway-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 42px -20px var(--c2);
  }

  /* The whole card is a single accessible button. Reset native button styling. */
  .takeaway-card__trigger {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    text-align: left;
    font: inherit;
    color: inherit;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
  }

  .takeaway-card__trigger:focus-visible {
    outline: 3px solid var(--c1);
    outline-offset: 3px;
    border-radius: 1.25rem;
  }

  .takeaway-card__band {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.05rem 1.2rem;
    background: linear-gradient(135deg, var(--c1), var(--c2));
  }

  .takeaway-card__band::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.16;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0);
    background-size: 18px 18px;
  }

  .takeaway-card__avatar {
    position: relative;
    z-index: 1;
    width: 3.25rem;
    height: 3.25rem;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.9), 0 4px 10px rgba(0, 0, 0, 0.25);
  }

  .takeaway-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .takeaway-card__id {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .takeaway-card__name {
    display: block;
    margin: 0;
    font-weight: 700;
    font-size: 0.98rem;
    line-height: 1.2;
    color: #fff;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .takeaway-card__sub {
    display: block;
    margin: 0.15rem 0 0;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .takeaway-card__body {
    position: relative;
    display: block;
    padding: 1.05rem 1.2rem 1.2rem;
  }

  .takeaway-card__quote {
    position: absolute;
    top: 0.1rem;
    left: 0.7rem;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.4rem;
    line-height: 1;
    color: var(--c1);
    opacity: 0.18;
    user-select: none;
  }

  .takeaway-card__text {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 5;
    line-clamp: 5;
    overflow: hidden;
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #374151;
  }

  .takeaway-card__more {
    display: inline-block;
    margin: 0.7rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c2);
    transition: transform 0.2s ease;
  }

  .takeaway-card__trigger:hover .takeaway-card__more,
  .takeaway-card__trigger:focus-visible .takeaway-card__more {
    transform: translateX(3px);
  }
</style>
