---
interface Props {
  name: string;
  nickname?: string;
  year: string;
  image: string;
  reflection: string;
  variant?: 'default' | 'featured';
}

const { name, nickname = '', year, image, reflection, variant = 'default' } = Astro.props;
const isPlaceholder = name === 'Your Full Name' || reflection.trim().length === 0;
const displayName = isPlaceholder ? 'Student Profile' : nickname ? `${name} (${nickname})` : name;
const subtitle = `${year} · Computer Science`;
const displayReflection = isPlaceholder ? 'Reflection coming soon.' : reflection;
---

{
  variant === 'featured' ? (
    <article
      class="break-inside-avoid mb-6 group relative rounded-3xl p-7 overflow-hidden hover:shadow-xl hover:shadow-primary/20 hover:-translate-y-1 transition-all duration-300 bg-brand-gradient"
    >
      <div
        class="absolute inset-0 opacity-15 pointer-events-none"
        style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 20px 20px;"
      ></div>
      <div class="absolute -right-10 -top-10 w-40 h-40 rounded-full bg-white/10 blur-2xl pointer-events-none"></div>

      <div class="relative flex items-center gap-4 mb-5">
        <div class="relative rounded-full overflow-hidden ring-2 ring-white/80 shadow-md shrink-0 w-14 h-14">
          <img src={image} alt={displayName} class="w-full h-full object-cover" />
        </div>
        <div class="min-w-0 flex-1">
          <h3 class="font-bold text-white truncate">{displayName}</h3>
          <p class="text-xs text-white/80 mt-0.5">{subtitle}</p>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -top-2 -left-1 text-6xl leading-none select-none pointer-events-none text-white/30 font-display">
          &ldquo;
        </div>
        <p class="relative text-sm text-white/95 leading-relaxed pl-5 pt-2">{displayReflection}</p>
      </div>
    </article>
  ) : (
    <article class="break-inside-avoid mb-6 group relative bg-white rounded-3xl p-7 border border-gray-100 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1 transition-all duration-300">
      <div class="absolute top-0 left-7 right-7 h-1 rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity bg-brand-gradient"></div>
      <div class="flex items-center gap-4 mb-5">
        <div class="relative rounded-full overflow-hidden ring-2 ring-white shadow-md shrink-0 w-16 h-16">
          <img src={image} alt={displayName} class="w-full h-full object-cover" />
        </div>
        <div class="min-w-0 flex-1">
          <h3 class="font-bold text-gray-900 truncate">{displayName}</h3>
          <p class="text-xs text-gray-500 mt-0.5">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary mr-1.5 align-middle"></span>
            {subtitle}
          </p>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -top-2 -left-1 text-6xl leading-none select-none pointer-events-none text-primary/15 font-display">
          &ldquo;
        </div>
        <p class="relative text-sm text-gray-600 leading-relaxed pl-5 pt-2">{displayReflection}</p>
      </div>
    </article>
  )
}
