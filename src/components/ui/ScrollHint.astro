---
import Icon from '../Icon.astro';

interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="mt-6 pt-5 border-t border-gray-100 flex items-center gap-3">
  <span class="text-[11px] font-bold tracking-[0.22em] uppercase text-gray-400 shrink-0">
    {label}
  </span>
  <div class="h-px flex-1 bg-gray-200"></div>
  <Icon name="chevron-down" size={16} class="text-primary shrink-0" />
</div>
