---
interface Props {
  letter: string;
  size?: 'md' | 'lg';
  class?: string;
}

const { letter, size = 'lg', class: className = '' } = Astro.props;
---

<div class:list={['relative pl-5 md:pl-6', className]}>
  <div class="absolute left-0 top-1 bottom-1 w-1 rounded-full bg-brand-gradient"></div>
  <p class="text-gray-800 leading-relaxed text-base md:text-lg">
    <span
      class:list={[
        'drop-cap float-left mt-0.5 leading-none',
        size === 'lg' ? 'drop-cap--lg' : 'drop-cap--md',
      ]}
    >
      {letter}
    </span>
    <slot />
  </p>
</div>
