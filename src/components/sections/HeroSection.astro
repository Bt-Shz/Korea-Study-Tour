---
import Icon from '../Icon.astro';
import { heroImages } from '../../data/hero';
import { trip } from '../../data/trip';
import { withBase } from '../../utils/paths';
---

<section class="relative h-screen min-h-[600px] flex items-end overflow-hidden" data-hero>
  {
    heroImages.map((img, index) => (
      <div
        class="absolute inset-0 transition-opacity duration-1000"
        style={`opacity: ${index === 0 ? '1' : '0'};`}
        data-hero-slide
        data-caption={img.caption}
      >
        <img src={withBase(img.url)} alt={img.caption} class="w-full h-full object-cover" />
      </div>
    ))
  }
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);"
  ></div>
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, rgba(200,16,46,0.25) 0%, transparent 60%);"
  ></div>

  <button
    type="button"
    data-hero-prev
    aria-label="Previous slide"
    class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full border border-white/25 bg-black/25 text-white backdrop-blur-sm hover:bg-black/45 hover:border-white/40 transition-colors flex items-center justify-center"
  >
    <Icon name="chevron-left" size={22} />
  </button>
  <button
    type="button"
    data-hero-next
    aria-label="Next slide"
    class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full border border-white/25 bg-black/25 text-white backdrop-blur-sm hover:bg-black/45 hover:border-white/40 transition-colors flex items-center justify-center"
  >
    <Icon name="chevron-right" size={22} />
  </button>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-5 pb-16 md:pb-20">
    <div class="max-w-3xl">
      <h1 class="font-display text-5xl md:text-7xl font-black text-white leading-[1.05] mb-4 tracking-tight">
        Seoul<br />
        <span class="text-brand-gradient" style="-webkit-text-fill-color: transparent;">
          Study
        </span><br />Tour 2026
      </h1>
      <p class="text-white/75 text-lg md:text-xl max-w-xl leading-relaxed">
        A five-day academic immersion into Korea's innovation ecosystem &mdash; from world-class
        universities to Seoul's smart-city control center.
      </p>
    </div>
    <div class="mt-10 flex items-center justify-between">
      <p class="text-white/50 text-xs tracking-widest uppercase" data-hero-caption>
        {heroImages[0].caption}
      </p>
      <div class="flex gap-1.5">
        {
          heroImages.map((_, index) => (
            <button
              type="button"
              data-hero-dot
              data-hero-index={index}
              aria-pressed={index === 0 ? 'true' : 'false'}
              class="rounded-full transition-all duration-300 h-1.5"
              style={`width: ${index === 0 ? '24px' : '6px'}; background: ${
                index === 0 ? 'var(--brand-orange)' : 'rgba(255,255,255,0.4)'
              };`}
            ></button>
          ))
        }
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-0 right-0 bg-white/10 backdrop-blur-md border-t border-white/10">
    <div class="max-w-7xl mx-auto px-5 py-3 grid grid-cols-2 gap-4 text-center">
      <div class="flex flex-col items-center text-white">
        <div class="flex items-center gap-1.5 text-white/60 text-xs mb-0.5">
          <Icon name="calendar" size={14} />
          {trip.dates.range}
        </div>
        <div class="font-bold text-sm md:text-base">{trip.dates.days} Days</div>
      </div>
      <div class="flex flex-col items-center text-white">
        <div class="flex items-center gap-1.5 text-white/60 text-xs mb-0.5">
          <Icon name="map-pin" size={14} />
          Academic Visits
        </div>
        <div class="font-bold text-sm md:text-base">{trip.venuesCount} Venues</div>
      </div>
    </div>
  </div>
</section>
