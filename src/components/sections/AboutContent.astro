---
import { institutionLinks, trip } from '../../data/trip';

const linkClass = 'text-primary hover:underline';
const { cityu, cityuCs, skku, kaistAi, koreaUniversity, yonsei, seoulGallery, seoulTopis } =
  institutionLinks;
---

<div class="space-y-5 text-gray-700 leading-relaxed text-[16px]">
  <p>
    The purpose of this website is to provide a window into a 5-day study tour that the{' '}
    <a href={cityuCs.href} class={linkClass} rel="noopener noreferrer" target="_blank">{cityuCs.label}</a> at{' '}
    <a href={cityu.href} class={linkClass} rel="noopener noreferrer" target="_blank">{cityu.label}</a>{' '}
    made possible. The trip took place {trip.dates.range}, aiming to expose students to a different
    educational system, introduce them to new collaboration and career opportunities, and expand
    their horizons.
  </p>
  <p>
    The itinerary included visits to{' '}
    <a href={skku.href} class={linkClass} rel="noopener noreferrer" target="_blank">{skku.label}</a>,{' '}
    <a href={kaistAi.href} class={linkClass} rel="noopener noreferrer" target="_blank">{kaistAi.label} ({kaistAi.shortName})</a>,{' '}
    <a href={koreaUniversity.href} class={linkClass} rel="noopener noreferrer" target="_blank">{koreaUniversity.label}</a>, and{' '}
    <a href={yonsei.href} class={linkClass} rel="noopener noreferrer" target="_blank">{yonsei.label}</a>.
    Our trip also included visits to{' '}
    <a href={seoulGallery.href} class={linkClass} rel="noopener noreferrer" target="_blank">{seoulGallery.label}</a> and{' '}
    <a href={seoulTopis.href} class={linkClass} rel="noopener noreferrer" target="_blank">{seoulTopis.label}</a>, where students explored Seoul's smart-city operations.
  </p>
  <p>
    The tour was led by the esteemed{' '}
    <a href="/visit-team" class={linkClass}>Dr. Howard Leung, Dr. Kenneth Lee, and Mr. Jacky Tam</a>
    from the Department of Computer Science at City University of Hong Kong.
  </p>
  <p class="font-medium text-gray-900">{trip.about.closing}</p>
</div>
