---
import { trip } from '../../data/trip';

const academicVenues = trip.venues.slice(0, 4);
const otherVenues = trip.venues.slice(4);
---

<div class="space-y-5 text-gray-700 leading-relaxed text-[16px]">
  <p>{trip.about.purpose}</p>
  <p>
    The itinerary included visits to{' '}
    {
      academicVenues.map((venue, index) => (
        <>
          {index > 0 && (index === academicVenues.length - 1 ? ', and ' : ', ')}
          {venue.url ? (
            <a
              href={venue.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary font-medium hover:underline"
            >
              {venue.name}
            </a>
          ) : (
            venue.name
          )}
        </>
      ))
    }
    . Our trip also included visits to{' '}
    {
      otherVenues.map((venue, index) => (
        <>
          {index > 0 && (index === otherVenues.length - 1 ? ', and ' : ', ')}
          {venue.url ? (
            <a
              href={venue.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary font-medium hover:underline"
            >
              {venue.name}
            </a>
          ) : (
            venue.name
          )}
        </>
      ))
    }
    , where students explored Seoul's smart-city operations.
  </p>
  <p>{trip.about.leadership}</p>
  <p class="font-medium text-gray-900">{trip.about.closing}</p>
</div>
