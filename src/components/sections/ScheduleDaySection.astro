---
import ScheduleEventItem from '../cards/ScheduleEventItem.astro';

interface EventItem {
  time: string;
  title: string;
  description: string;
  variant?: 'default' | 'travel' | 'staying-behind';
}

interface Props {
  date: string;
  summary: string;
  dayNumber: number;
  events: readonly EventItem[];
}

const { date, summary, dayNumber, events } = Astro.props;
---

<section class="rounded-3xl border border-gray-200 bg-white p-6 md:p-8 shadow-sm">
  <div class="flex items-start gap-4">
    <div class="w-11 h-11 rounded-xl bg-brand-gradient text-white font-black flex items-center justify-center shrink-0">
      {dayNumber}
    </div>
    <div>
      <h2 class="text-2xl font-display font-bold text-gray-900">{date}</h2>
      <p class="text-sm text-gray-500 mt-1">{summary}</p>
    </div>
  </div>

  <div class="mt-6 space-y-4">
    {events.map((event) => <ScheduleEventItem {...event} />)}
  </div>
</section>
