---
import ScheduleEventItem from '../cards/ScheduleEventItem.astro';
import Icon from '../Icon.astro';

interface Participant {
  name: string;
  image: string;
}

interface EventItem {
  time: string;
  title: string;
  description: string;
  slug?: string;
  location?: string;
  variant?: 'default' | 'travel' | 'staying-behind';
  icon?:
    | 'plane'
    | 'train'
    | 'graduation'
    | 'utensils'
    | 'landmark'
    | 'compass'
    | 'image';
  steps?: readonly string[];
  participants?: readonly Participant[];
}

interface Props {
  date: string;
  summary: string;
  dayNumber: number;
  events: readonly EventItem[];
}

const { date, summary, dayNumber, events } = Astro.props;
const stopCount = events.length;
---

<details class="schedule-day" id={`day-${dayNumber}`} open>
  <summary class="schedule-day-summary">
    <div class="schedule-day-summary-inner">
      <span class="schedule-day-number">
        <span class="schedule-day-number-label">Day</span>
        <span class="schedule-day-number-value">{dayNumber}</span>
      </span>
      <div class="schedule-day-meta">
        <h3 class="schedule-date">{date}</h3>
        <p class="schedule-summary">{summary}</p>
        <span class="schedule-day-count">
          {stopCount}
          {stopCount === 1 ? 'stop' : 'stops'}
        </span>
      </div>
      <span class="schedule-day-toggle" aria-hidden="true">
        <Icon name="chevron-down" size={18} strokeWidth={2.4} />
      </span>
    </div>
  </summary>

  <div class="schedule-day-content">
    <ul class="schedule-events">
      {events.map((event) => (
        <ScheduleEventItem {...event} />
      ))}
    </ul>
  </div>
</details>
