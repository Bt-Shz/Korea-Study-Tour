---
import ScheduleEventItem from '../cards/ScheduleEventItem.astro';

interface Participant {
  name: string;
  image: string;
}

interface EventItem {
  time: string;
  title: string;
  description: string;
  slug?: string;
  location?: string;
  variant?: 'default' | 'travel' | 'staying-behind';
  steps?: readonly string[];
  participants?: readonly Participant[];
}

interface Props {
  date: string;
  summary: string;
  dayNumber: number;
  events: readonly EventItem[];
}

const { date, summary, dayNumber, events } = Astro.props;
---

<details class="schedule-day" open>
  <summary class="schedule-day-summary">
    <div class="schedule-day-summary-inner">
      <span class="schedule-day-number">{dayNumber}</span>
      <div class="schedule-day-meta">
        <h3 class="schedule-date">{date}</h3>
        <p class="schedule-summary">{summary}</p>
      </div>
      <span class="schedule-day-toggle">▼</span>
    </div>
  </summary>

  <div class="schedule-day-content">
    <ul class="schedule-events">
      {events.map((event) => (
        <ScheduleEventItem {...event} />
      ))}
    </ul>
  </div>
</details>
