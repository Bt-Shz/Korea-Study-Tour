---
import type { SocialFallbackCard } from '../../data/social-fallbacks';
import { withBase } from '../../utils/paths';

interface Props extends SocialFallbackCard {}

const { href, image, imageAlt, title, meta, external = false } = Astro.props;
const cardHref = external ? href : withBase(href);
const imageSrc = withBase(image);
---

<a
  href={cardHref}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="social-card group flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
>
  <img
    src={imageSrc}
    alt={imageAlt}
    loading="lazy"
    decoding="async"
    class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
  />
  <div class="social-card-body flex flex-1 flex-col gap-1 p-4">
    <h3 class="social-card-title text-sm font-semibold leading-snug text-gray-900 group-hover:text-primary">
      {title}
    </h3>
    <p class="social-card-meta text-xs text-gray-500">{meta}</p>
  </div>
</a>
