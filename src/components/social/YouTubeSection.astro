---
import { youtubeEmbeds } from '../../data/social-embeds';
import { youtubeFallback } from '../../data/social-fallbacks';
import SocialEmbedSlot from './SocialEmbedSlot.astro';
import SocialFallbackGrid from './SocialFallbackGrid.astro';
---

<div class="social-platform-section" aria-labelledby="us-on-youtube">
  <h3 id="us-on-youtube" class="sr-only">Us on YouTube</h3>

  <div id="youtube-embeds" class="scrolling-wrapper cv-auto">
    {
      youtubeEmbeds.map((embed, index) => (
        <SocialEmbedSlot href={embed.watchUrl} label="Open on YouTube" frameClass="youtube-embed-frame">
          <iframe
            src={`https://www.youtube.com/embed/${embed.videoId}`}
            title={`Embedded YouTube video ${index + 1}`}
            loading="lazy"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            data-fallback-target="youtube-fallback"
            data-embed-wrapper="youtube-embeds"
          />
        </SocialEmbedSlot>
      ))
    }
  </div>

  <SocialFallbackGrid
    id="youtube-fallback"
    message={youtubeFallback.message}
    cards={youtubeFallback.cards}
    hidden
  />
</div>
