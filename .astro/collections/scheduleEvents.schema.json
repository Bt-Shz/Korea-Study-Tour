{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "time": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "dayNumber": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "date": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "time",
    "location",
    "image",
    "dayNumber",
    "date",
    "summary"
  ]
}